   "source": [
    "\n",
    "import os \n",
    "os.environ[\"OPENBLAS_NUM_THREADS\"]=\"1\"\n",
    "import numpy as np\n",
    "matrix = np.array([[2,2],[1,3]])\n",
    "eig_val,eig_vec = np.linalg.eig(matrix)\n",
    "\n",
    "print(f\"Eigen values are {eig_val} and Eigen Vectors are {eig_vec}\")"
   ]
